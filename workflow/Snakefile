"""Snakemake workflow for Walcheren population synthesis.

Run with:
    uv run snakemake --cores 1 -s workflow/Snakefile
"""


rule all:
    input:
        "data/processed/walcheren_population.parquet",
        "data/processed/walcheren_skim_car.omx",
        "data/processed/walcheren_skim_bike.omx",
        "data/processed/walcheren_network_car_nodes.parquet",
        "data/processed/walcheren_network_car_edges.parquet",
        "data/processed/walcheren_network_bike_nodes.parquet",
        "data/processed/walcheren_network_bike_edges.parquet",
        "data/processed/walcheren_pois.parquet",
        "data/processed/walcheren_pois.gpkg",


rule download_boundaries:
    output:
        "data/raw/walcheren_gemeenten.geojson",
    shell:
        "uv run python workflow/scripts/download_boundaries.py"


rule download_network:
    input:
        boundaries="data/raw/walcheren_gemeenten.geojson",
    output:
        "data/processed/walcheren_network_{mode}.graphml",
    wildcard_constraints:
        mode="car|bike",
    shell:
        "uv run python workflow/scripts/download_network.py"
        " --mode {wildcards.mode}"


rule build_skim:
    input:
        network="data/processed/walcheren_network_{mode}.graphml",
        grid="data/processed/walcheren_grid_clean.parquet",
    output:
        "data/processed/walcheren_skim_{mode}.omx",
    wildcard_constraints:
        mode="car|bike",
    shell:
        "uv run python workflow/scripts/build_skim.py"
        " --mode {wildcards.mode}"


rule fetch_pois:
    input:
        "data/raw/walcheren_gemeenten.geojson",
        "data/processed/walcheren_grid_clean.parquet",
    output:
        "data/processed/walcheren_pois.parquet",
        "data/processed/walcheren_pois.gpkg",
    shell:
        "uv run python workflow/scripts/fetch_pois.py"


rule filter_grid:
    input:
        grid="data/raw/2025-cbs_vk100_2024_v1.zip",
        boundaries="data/raw/walcheren_gemeenten.geojson",
    output:
        "data/processed/walcheren_grid_raw.parquet",
    shell:
        "uv run python workflow/scripts/filter_grid.py"


rule clean:
    input:
        "data/processed/walcheren_grid_raw.parquet",
    output:
        "data/processed/walcheren_grid_clean.parquet",
    shell:
        "uv run python workflow/scripts/clean_grid.py"


rule build_specs:
    input:
        "data/processed/walcheren_grid_clean.parquet",
    output:
        "data/processed/walcheren_zone_specs.parquet",
    shell:
        "uv run python workflow/scripts/build_specs.py"


rule synthesize:
    input:
        "data/processed/walcheren_zone_specs.parquet",
    output:
        "data/processed/walcheren_population.parquet",
    shell:
        "uv run python workflow/scripts/synthesize.py"


rule export_network:
    input:
        network="data/processed/walcheren_network_{mode}.graphml",
    output:
        nodes="data/processed/walcheren_network_{mode}_nodes.parquet",
        edges="data/processed/walcheren_network_{mode}_edges.parquet",
    wildcard_constraints:
        mode="car|bike",
    shell:
        "uv run python workflow/scripts/export_network.py"
        " --mode {wildcards.mode}"
