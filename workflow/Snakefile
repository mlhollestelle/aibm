"""Snakemake workflow for the Walcheren example model.

Run with:
    uv run snakemake --cores 1 -s workflow/Snakefile
"""

import yaml as _yaml

configfile: "workflow/config.yaml"

NAME = config["study_area"]["name"]
MODES = config["network"]["modes"]
TRANSIT = config.get("transit", {}).get("enabled", False)

PROVIDERS = config.get("providers", [])
ITERATIONS = config.get("iterations", ["baseline"])
POLICIES = config.get("policies", ["baseline"])


def _build_scenarios():
    """Build provider×iteration×policy cross-product, respecting only_iterations."""
    scenarios = []
    for p in PROVIDERS:
        p_path = f"workflow/providers/{p}.yaml"
        with open(p_path) as _f:
            p_cfg = _yaml.safe_load(_f) or {}
        allowed = p_cfg.get("only_iterations", ITERATIONS)
        for i in ITERATIONS:
            if i in allowed:
                for pol in POLICIES:
                    scenarios.append(f"{p}__{i}__{pol}")
    return scenarios


SCENARIOS = _build_scenarios()


def _provider(scenario):
    return scenario.split("__")[0]


def _iteration(scenario):
    return scenario.split("__")[1]


def _policy(scenario):
    parts = scenario.split("__")
    return parts[2] if len(parts) >= 3 else "baseline"


rule all:
    input:
        f"data/processed/{NAME}_population.parquet",
        f"data/processed/{NAME}_population_report.txt",
        expand(
            "data/processed/{NAME}_skim_{mode}_{policy}.omx",
            NAME=NAME,
            mode=[m for m in MODES if m != "transit"],
            policy=POLICIES,
        ),
        expand(
            "data/processed/{NAME}_network_{mode}_nodes.parquet",
            NAME=NAME,
            mode=MODES,
        ),
        expand(
            "data/processed/{NAME}_network_{mode}_edges.parquet",
            NAME=NAME,
            mode=MODES,
        ),
        f"data/processed/{NAME}_pois.parquet",
        f"data/processed/{NAME}_pois.gpkg",
        expand(
            "data/processed/{NAME}_assigned_trips_{scenario}.parquet",
            NAME=NAME,
            scenario=SCENARIOS,
        ),
        f"data/processed/{NAME}_mode_shares.png",
        f"data/processed/{NAME}_trip_lengths.png",
        f"data/processed/{NAME}_trips_per_person.png",
        *([f"data/processed/{NAME}_transit_stops.graphml",
           f"data/processed/{NAME}_skim_transit.omx"] if TRANSIT else []),


rule download_boundaries:
    output:
        f"data/raw/{NAME}_gemeenten.geojson",
    shell:
        "uv run python workflow/scripts/download_boundaries.py"
        " --config workflow/config.yaml"


rule download_network:
    input:
        boundaries=f"data/raw/{NAME}_gemeenten.geojson",
    output:
        f"data/processed/{NAME}_network_{{mode}}.graphml",
    wildcard_constraints:
        mode="car|bike|walk",
    shell:
        "uv run python workflow/scripts/download_network.py"
        " --mode {wildcards.mode}"
        " --config workflow/config.yaml"


rule build_skim:
    input:
        network=f"data/processed/{NAME}_network_{{mode}}.graphml",
        grid=f"data/processed/{NAME}_grid_clean.parquet",
    output:
        f"data/processed/{NAME}_skim_{{mode}}_{{policy}}.omx",
    wildcard_constraints:
        mode="car|bike|walk",
        policy="[a-z0-9_]+",
    shell:
        "uv run python workflow/scripts/build_skim.py"
        " --mode {wildcards.mode}"
        " --policy {wildcards.policy}"
        " --config workflow/config.yaml"


rule fetch_pois:
    input:
        f"data/raw/{NAME}_gemeenten.geojson",
        f"data/processed/{NAME}_grid_clean.parquet",
    output:
        f"data/processed/{NAME}_pois.parquet",
        f"data/processed/{NAME}_pois.gpkg",
    shell:
        "uv run python workflow/scripts/fetch_pois.py"
        " --config workflow/config.yaml"


rule filter_grid:
    input:
        grid=f"data/raw/{config['grid']['raw_zip']}",
        boundaries=f"data/raw/{NAME}_gemeenten.geojson",
    output:
        f"data/processed/{NAME}_grid_raw.parquet",
    shell:
        "uv run python workflow/scripts/filter_grid.py"
        " --config workflow/config.yaml"


rule clean:
    input:
        f"data/processed/{NAME}_grid_raw.parquet",
    output:
        f"data/processed/{NAME}_grid_clean.parquet",
    shell:
        "uv run python workflow/scripts/clean_grid.py"
        " --config workflow/config.yaml"


rule build_specs:
    input:
        f"data/processed/{NAME}_grid_clean.parquet",
    output:
        f"data/processed/{NAME}_zone_specs.parquet",
    shell:
        "uv run python workflow/scripts/build_specs.py"
        " --config workflow/config.yaml"


rule synthesize:
    input:
        f"data/processed/{NAME}_zone_specs.parquet",
    output:
        f"data/processed/{NAME}_population.parquet",
    shell:
        "uv run python workflow/scripts/synthesize.py"
        " --config workflow/config.yaml"


rule validate_population:
    input:
        population=f"data/processed/{NAME}_population.parquet",
        zone_specs=f"data/processed/{NAME}_zone_specs.parquet",
    output:
        f"data/processed/{NAME}_population_report.txt",
    shell:
        "uv run python workflow/scripts/validate_population.py"
        " --config workflow/config.yaml"


rule export_network:
    input:
        network=f"data/processed/{NAME}_network_{{mode}}.graphml",
    output:
        nodes=f"data/processed/{NAME}_network_{{mode}}_nodes.parquet",
        edges=f"data/processed/{NAME}_network_{{mode}}_edges.parquet",
    wildcard_constraints:
        mode="car|bike|walk",
    shell:
        "uv run python workflow/scripts/export_network.py"
        " --mode {wildcards.mode}"
        " --config workflow/config.yaml"


rule sample_households:
    input:
        f"data/processed/{NAME}_population.parquet",
        f"data/processed/{NAME}_population_report.txt",
    output:
        f"data/processed/{NAME}_sample.parquet",
    shell:
        "uv run python workflow/scripts/sample_households.py"
        " --config workflow/config.yaml"


rule simulate:
    input:
        sample=f"data/processed/{NAME}_sample.parquet",
        pois=f"data/processed/{NAME}_pois.parquet",
        zone_specs=f"data/processed/{NAME}_zone_specs.parquet",
        skims=lambda wc: expand(
            "data/processed/{NAME}_skim_{mode}_{policy}.omx",
            NAME=NAME,
            mode=[m for m in MODES if m != "transit"],
            policy=_policy(wc.scenario),
        ),
        skim_transit=(
            [f"data/processed/{NAME}_skim_transit.omx"] if TRANSIT else []
        ),
        provider_yaml=lambda wc: f"workflow/providers/{_provider(wc.scenario)}.yaml",
        iteration_yaml=lambda wc: f"workflow/iterations/{_iteration(wc.scenario)}.yaml",
        policy_yaml=lambda wc: f"workflow/policies/{_policy(wc.scenario)}.yaml",
    output:
        trips=f"data/processed/{NAME}_trips_{{scenario}}.parquet",
        day_plans=f"data/processed/{NAME}_day_plans_{{scenario}}.parquet",
    shell:
        "uv run python workflow/scripts/simulate.py"
        " --config workflow/config.yaml"
        " --scenario {wildcards.scenario}"


rule assign_network:
    input:
        trips=f"data/processed/{NAME}_trips_{{scenario}}.parquet",
        networks=expand(
            "data/processed/{NAME}_network_{mode}.graphml", NAME=NAME, mode=MODES
        ),
        grid=f"data/processed/{NAME}_grid_clean.parquet",
        zone_specs=f"data/processed/{NAME}_zone_specs.parquet",
        transit_stops=(
            [f"data/processed/{NAME}_transit_stops.graphml"] if TRANSIT else []
        ),
    output:
        f"data/processed/{NAME}_assigned_trips_{{scenario}}.parquet",
    shell:
        "uv run python workflow/scripts/assign_network.py"
        " --config workflow/config.yaml"
        " --scenario {wildcards.scenario}"


rule plot_mode_shares:
    input:
        expand(
            "data/processed/{NAME}_assigned_trips_{scenario}.parquet",
            NAME=NAME,
            scenario=SCENARIOS,
        ),
    output:
        f"data/processed/{NAME}_mode_shares.png",
    shell:
        "uv run python workflow/scripts/plot_mode_shares.py"
        " --config workflow/config.yaml"
        " --output {output}"


rule plot_trip_lengths:
    input:
        expand(
            "data/processed/{NAME}_assigned_trips_{scenario}.parquet",
            NAME=NAME,
            scenario=SCENARIOS,
        ),
    output:
        f"data/processed/{NAME}_trip_lengths.png",
    shell:
        "uv run python workflow/scripts/plot_trip_lengths.py"
        " --config workflow/config.yaml"
        " --output {output}"


rule plot_trips_per_person:
    input:
        expand(
            "data/processed/{NAME}_assigned_trips_{scenario}.parquet",
            NAME=NAME,
            scenario=SCENARIOS,
        ),
    output:
        f"data/processed/{NAME}_trips_per_person.png",
    shell:
        "uv run python workflow/scripts/plot_trips_per_person.py"
        " --config workflow/config.yaml"
        " --output {output}"


rule download_transit:
    input:
        boundaries=f"data/raw/{NAME}_gemeenten.geojson",
    output:
        f"data/processed/{NAME}_transit_stops.graphml",
    shell:
        "uv run python workflow/scripts/download_transit.py"
        " --config workflow/config.yaml"


rule build_transit_skim:
    input:
        transit_stops=f"data/processed/{NAME}_transit_stops.graphml",
        walk_network=f"data/processed/{NAME}_network_walk.graphml",
        grid=f"data/processed/{NAME}_grid_clean.parquet",
    output:
        f"data/processed/{NAME}_skim_transit.omx",
    shell:
        "uv run python workflow/scripts/build_transit_skim.py"
        " --config workflow/config.yaml"
